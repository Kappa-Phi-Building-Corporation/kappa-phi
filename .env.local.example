# Supabase — from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL — used in email links and auth redirects
NEXT_PUBLIC_SITE_URL=https://kappa-phi.org

# Email — Resend (https://resend.com)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@kappa-phi.org
ADMIN_EMAIL=kappaphi@kappa-phi.org
PROPERTY_ISSUE_EMAIL=                        # where property issue reports are sent; defaults to ADMIN_EMAIL

# Cloudflare Turnstile (CAPTCHA) — get keys from https://dash.cloudflare.com/?to=/:account/turnstile
# If left blank, the CAPTCHA widget is hidden and verification is skipped.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
